# Lochmere Golf Club EZLinks credentials
EZLINKS_USERNAME=your_username
EZLINKS_PASSWORD=your_password

# Anthropic API key for browser-use AI agent
ANTHROPIC_API_KEY=your_api_key

# Booking preferences
TARGET_TIME=08:28
NUM_PLAYERS=4
BOOKING_URL=https://lochmeregm.ezlinksgolf.com
DAYS_OUT=14

# Drop-window tuning (all have sensible defaults — only override to debug)
# Skip the at-drop poll: first post-drop poll fires at drop + this many ms.
# Avoids the brief server flap at the exact drop instant.
# DROP_OFFSET_MS=500
# On a transient HTTP failure during polling, fast-retry every this many ms
# instead of waiting the full 5s POLL_INTERVAL.
# FAST_RETRY_DELAY_MS=500
# Max consecutive fast retries before falling back to normal poll cadence.
# FAST_RETRY_DELAY_MS=500 * MAX_FAST_RETRIES=6 = ~3s of fast retries.
# MAX_FAST_RETRIES=6
